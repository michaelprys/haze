{
    "name": "haze",
    "version": "0.0.1",
    "description": "A space where people express themselves",
    "productName": "Haze",
    "author": "musha09cz@gmail.com <musha09cz@gmail.com>",
    "type": "module",
    "private": true,
    "scripts": {
        "lint": "eslint -c ./eslint.config.js \"./src/**/*.{ts,js,cjs,mjs,vue}\"",
        "lint:fix": "eslint --fix -c ./eslint.config.js \"./src/**/*.{ts,js,cjs,mjs,vue}\"",
        "style:lint:fix": "stylelint \"src/**/*.{vue,scss,css}\" --fix",
        "format": "prettier --write \"src/**/*.{ts,vue,scss,css,js}\"",
        "test": "echo \"No test specified\" && exit 0",
        "dev": "quasar dev",
        "build": "pnpm run lint:fix && pnpm run style:lint:fix && pnpm run format && quasar build",
        "postinstall": "quasar prepare"
    },
    "dependencies": {
        "@quasar/extras": "^1.17.0",
        "@supabase/supabase-js": "^2.98.0",
        "pinia": "^3.0.4",
        "pinia-plugin-persistedstate": "^4.7.1",
        "quasar": "^2.18.6",
        "stylelint-order": "^8.0.0",
        "vue": "^3.5.29",
        "vue-router": "^5.0.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@quasar/app-vite": "^2.4.1",
        "@types/node": "^25.3.5",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.7.0",
        "autoprefixer": "^10.4.27",
        "eslint": "9.39.3",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^17.4.0",
        "postcss-html": "^1.8.1",
        "prettier": "^3.8.1",
        "stylelint": "^17.4.0",
        "stylelint-config-recommended-scss": "^17.0.0",
        "stylelint-config-recommended-vue": "^1.6.1",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-scss": "^7.0.0",
        "typescript": "^5.9.3",
        "vite-plugin-checker": "^0.12.0",
        "vue-eslint-parser": "^10.4.0",
        "vue-tsc": "^3.2.5"
    },
    "engines": {
        "node": "^28 || ^26 || ^24 || ^22 || ^20",
        "npm": ">= 6.13.4",
        "yarn": ">= 1.21.1",
        "pnpm": ">= 10.0.0"
    }
}
